{
  "name": "house-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.2.2"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit lib worker/jobs components",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "bash tests/e2e/run-local.sh",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "test:a11y:local": "bash tests/e2e/run-local.sh tests/e2e/a11y.spec.ts",
    "test:visual:local": "bash tests/e2e/run-visual.sh",
    "test:visual:update": "bash tests/e2e/run-visual.sh --update-snapshots",
    "test:local": "pnpm test:unit && pnpm test:integration && pnpm test:e2e:local && pnpm test:coverage:check",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && pnpm lint:tokens && pnpm lint:knip",
    "lint:fix": "biome check --write .",
    "lint:knip": "knip",
    "lint:tokens": "node scripts/lint-css-tokens.mjs",
    "format": "biome format --write .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "worker:dev": "tsx worker/index.ts",
    "worker:start": "tsx worker/index.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.98.0",
    "@auth/prisma-adapter": "2.11.2",
    "@base-ui/react": "1.5.0",
    "@hookform/resolvers": "5.4.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-slot": "1.2.4",
    "@sentry/nextjs": "10.53.1",
    "@sentry/node": "10.53.1",
    "@types/hast": "3.0.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "file-type": "22.0.1",
    "hast-util-from-html": "2.0.3",
    "hast-util-sanitize": "5.0.2",
    "hast-util-to-jsx-runtime": "2.3.6",
    "ical-generator": "10.2.0",
    "lucide-react": "1.16.0",
    "meilisearch": "0.58.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "0.4.6",
    "pdf-to-png-converter": "4.0.0",
    "pg": "8.21.0",
    "pg-boss": "12.18.2",
    "pino": "10.3.1",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "react-markdown": "10.1.0",
    "rehype-sanitize": "6.0.0",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "rrule": "2.8.1",
    "sharp": "0.34.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tesseract.js": "7.0.0",
    "tsx": "4.22.3",
    "tw-animate-css": "1.4.0",
    "unpdf": "1.6.2",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testcontainers/postgresql": "12.0.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "4.1.7",
    "axe-core": "4.11.4",
    "jsdom": "29.1.1",
    "knip": "6.14.2",
    "lefthook": "2.1.8",
    "pino-pretty": "13.1.3",
    "shadcn": "4.8.0",
    "tailwindcss": "4.3.0",
    "testcontainers": "12.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
