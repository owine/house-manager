{
  "name": "house-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "~24.15.0",
    "pnpm": "~10.33.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit lib worker/jobs",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "bash tests/e2e/run-local.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "worker:dev": "tsx worker/index.ts",
    "worker:start": "tsx worker/index.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.92.0",
    "@auth/prisma-adapter": "~2.11.2",
    "@base-ui/react": "~1.4.1",
    "@hookform/resolvers": "~5.2.2",
    "@paralleldrive/cuid2": "~3.3.0",
    "@prisma/adapter-pg": "~7.8.0",
    "@prisma/client": "~7.8.0",
    "@radix-ui/react-slot": "~1.2.4",
    "@sentry/nextjs": "~10.51.0",
    "@sentry/node": "~10.51.0",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "file-type": "~22.0.1",
    "ical-generator": "~10.2.0",
    "lucide-react": "~1.14.0",
    "meilisearch": "~0.58.0",
    "next": "~16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "~0.4.6",
    "pg": "~8.20.0",
    "pg-boss": "~12.18.2",
    "pino": "~10.3.1",
    "prisma": "~7.8.0",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "react-hook-form": "~7.75.0",
    "react-markdown": "~10.1.0",
    "rehype-sanitize": "~6.0.0",
    "remark-gfm": "~4.0.1",
    "rrule": "~2.8.1",
    "sharp": "~0.34.5",
    "sonner": "~2.0.7",
    "tailwind-merge": "~3.5.0",
    "tsx": "~4.21.0",
    "tw-animate-css": "~1.4.0",
    "web-push": "~3.6.7",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.14",
    "@playwright/test": "~1.59.1",
    "@tailwindcss/postcss": "~4.2.4",
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "~25.6.0",
    "@types/pg": "~8.20.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@types/web-push": "~3.6.4",
    "@vitest/coverage-v8": "4.1.5",
    "lefthook": "~2.1.6",
    "pino-pretty": "~13.1.3",
    "shadcn": "~4.6.0",
    "tailwindcss": "~4.2.4",
    "testcontainers": "11.14.0",
    "typescript": "~6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.12": "~8.5.13",
      "uuid@<14.0.0": "~14.0.0",
      "@hono/node-server@<2.0.1": "~2.0.1"
    }
  }
}
