{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>owine/renovate-config",
    "github>owine/renovate-config:automerge",
    "github>owine/renovate-config:node",
    "github>owine/renovate-config:docker"
  ],
  "enabledManagers": [
    "npm",
    "github-actions",
    "dockerfile",
    "nvm",
    "pre-commit",
    "custom.regex",
    "custom.jsonata"
  ],
  "customManagers": [
    {
      "customType": "jsonata",
      "datasourceTemplate": "npm",
      "depNameTemplate": "@biomejs/biome",
      "fileFormat": "json",
      "managerFilePatterns": ["**/biome.{json,jsonc}"],
      "matchStrings": ["{\"currentValue\": $split($.\"$schema\",(\"/\"))[-2]}"]
    }
  ],
  "packageRules": [
    {
      "description": "GitGuardian (action + ggshield CLI) must stay version-consistent",
      "matchPackageNames": ["GitGuardian/ggshield-action", "ggshield"],
      "groupName": "gitguardian"
    }
  ]
}
