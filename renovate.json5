{
  // House Manager Renovate config.
  // Docs: https://docs.renovatebot.com/configuration-options/
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',

  extends: [
    'config:recommended',
    ':dependencyDashboard',
    ':semanticCommits',
    'group:allNonMajor',
  ],

  timezone: 'America/Chicago',
  schedule: ['before 6am on monday'],

  // Tilde-pinned to semver patch in package.json (~x.y.z). Renovate keeps the
  // prefix shape and bumps the version when a higher minor/major is available.
  // Patch updates flow into the lockfile via lockFileMaintenance below without
  // needing a Renovate PR per patch.
  rangeStrategy: 'bump',

  // Refresh the lockfile weekly to catch transitive updates.
  lockFileMaintenance: {
    enabled: true,
    schedule: ['before 6am on monday'],
  },

  // Cap PR noise.
  prHourlyLimit: 4,
  prConcurrentLimit: 10,

  // Auto-merge security fixes immediately.
  vulnerabilityAlerts: {
    labels: ['security'],
    automerge: true,
  },

  packageRules: [
    {
      description: 'Auto-merge patch updates and lockfile maintenance once CI passes',
      matchUpdateTypes: ['patch', 'pinDigest', 'lockFileMaintenance'],
      automerge: true,
      automergeType: 'pr',
    },
    {
      description: 'Major updates require manual review',
      matchUpdateTypes: ['major'],
      automerge: false,
      labels: ['major-update'],
    },
    {
      description: 'Group Prisma packages so adapter + client + CLI bump together',
      matchPackageNames: ['@prisma/client', '@prisma/adapter-pg', 'prisma'],
      groupName: 'prisma',
    },
    {
      description: 'Group Auth.js packages',
      matchPackageNames: ['next-auth', '@auth/prisma-adapter'],
      groupName: 'auth.js',
    },
    {
      description: 'Group testing packages (vitest + testcontainers families)',
      matchPackageNames: [
        'vitest',
        '@vitest/coverage-v8',
        'testcontainers',
        '@testcontainers/postgresql',
      ],
      groupName: 'testing',
    },
    {
      description: 'Group React + types together',
      matchPackageNames: ['react', 'react-dom', '@types/react', '@types/react-dom'],
      groupName: 'react',
    },
    {
      description: 'Group pg + types together',
      matchPackageNames: ['pg', '@types/pg'],
      groupName: 'pg',
    },
    {
      description: 'Pin Docker image digests so updates surface as Renovate PRs',
      matchManagers: ['docker-compose', 'dockerfile'],
      pinDigests: true,
    },
  ],
}
