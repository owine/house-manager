# Supply-chain hardening for pnpm
# Wait 7 days before installing any newly-published version — catches
# yanked or compromised releases (compromised-maintainer attacks like
# the npm `event-stream` or 2024 `ua-parser-js` incidents are typically
# detected and yanked within hours-to-days).
minimum-release-age=10080

# Refuse to install if the lockfile is out of sync (CI safety)
prefer-frozen-lockfile=true

# `pnpm add` writes exact versions, never caret/tilde ranges
save-exact=true

# `pnpm audit` fails on moderate+ vulnerabilities
audit-level=moderate
