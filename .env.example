# Required at runtime — see docs/README.md "Environment variables" for the
# authoritative list and constraints. lib/env.ts validates these via Zod at
# first getEnv() call and fails fast if anything is missing or malformed.

# Database (app reads DATABASE_URL; the POSTGRES_* vars are for the db service)
DATABASE_URL=postgresql://housemanager:devpassword@localhost:5432/housemanager
POSTGRES_USER=housemanager
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=housemanager

# Auth (Auth.js + Authelia OIDC)
AUTH_SECRET=<generate with `openssl rand -base64 32`>
AUTH_URL=http://localhost:3000
AUTH_OIDC_ISSUER=https://auth.example.com
AUTH_OIDC_CLIENT_ID=house-manager
AUTH_OIDC_CLIENT_SECRET=<from Authelia client config>

# Meilisearch (app reads MEILI_KEY; MEILI_MASTER_KEY is for the meilisearch service)
MEILI_HOST=http://localhost:7700
MEILI_KEY=<generate with `openssl rand -hex 32`>
MEILI_MASTER_KEY=<same as MEILI_KEY>

# Files (attachment storage; mounted as a volume in compose)
FILES_DIR=./data/files

# Web Push (generate with `pnpm dlx web-push generate-vapid-keys`)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_CONTACT_EMAIL=mailto:admin@example.com

# Email (ForwardEmail for reminder delivery)
FORWARDEMAIL_API_KEY=
FORWARDEMAIL_FROM_ADDRESS=reminders@example.com

# Inbound email webhook (ForwardEmail "inbox:" alias forwards parsed mail here).
# Both vars are optional — leave blank to disable the inbox feature, in which
# case POSTs to /api/inbound-email/[token] return 503. To enable: generate
# token with `openssl rand -hex 24` and place same value in DNS TXT URL path
# and here. Set HMAC_KEY in ForwardEmail dashboard → Domains → Settings →
# "Webhook Signature Payload Verification Key" and copy that value here.
# When set, both must be 16+ chars.
# INBOUND_EMAIL_TOKEN=
# INBOUND_EMAIL_HMAC_KEY=

# Optional
# APP_URL=http://localhost:3000   # absolute base URL for emails / push payloads
NODE_ENV=development

# AI (Anthropic — required by lib/env.ts; get a real key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-example-placeholder-replace-with-real-key
